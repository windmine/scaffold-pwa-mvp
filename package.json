{
  "name": "scaffold-pwa-mvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate:pwa": "node scripts/generate-pwa-service-worker.mjs",
    "dev": "npm run generate:pwa && vite",
    "dev:phone": "npm run generate:pwa && vite --host 0.0.0.0 --port 5173",
    "build": "npm run generate:pwa && vite build",
    "check:mobile": "npm run check:mobile:static && npm run check:browser",
    "check:mobile:static": "npm run generate:pwa && node scripts/check-mobile-browser-workflows.mjs",
    "check:browser": "npm run generate:pwa && node scripts/check-browser-workflows.mjs",
    "check:review-queue": "node scripts/review-queue-module-test.mjs && python backend/review_queue_test.py",
    "check:production-hardening": "powershell -ExecutionPolicy Bypass -File scripts/check-production-hardening.ps1 -AllowIncidentOnlyMonitoring",
    "check:production-hardening:strict": "powershell -ExecutionPolicy Bypass -File scripts/check-production-hardening.ps1",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:phone": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "playwright": "^1.61.1",
    "vite": "^8.1.4"
  }
}
