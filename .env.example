# Backend
# Generate a stronger local value before real deployment.
APP_ENV=development
GEO_SECRET_KEY=change-this-dev-secret
GEO_JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=sqlite:///./geo_management.db
BUSINESS_TIMEZONE=Pacific/Auckland
AUTO_MIGRATE=true
SQL_ECHO=false
ENABLE_DEV_SEED=true
AUTH_COOKIE_SECURE=false

# Lightweight in-process abuse throttling. Defaults to enabled in production-like
# environments and disabled in local development unless set here.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_GENERAL_REQUESTS=300
RATE_LIMIT_GENERAL_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=30
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD_REQUESTS=30
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=60

# Add your phone testing URL when needed, for example:
# CORS_ORIGINS=https://localhost:5173,https://127.0.0.1:5173,https://192.168.1.25:5173
CORS_ORIGINS=http://localhost:5173,https://localhost:5173,http://127.0.0.1:5173,https://127.0.0.1:5173

# Uploads
# Development uses local. Production-like APP_ENV values require gcs explicitly.
# New uploads are decoded and re-encoded as single-frame JPEG, PNG, or WebP.
UPLOAD_DIR=uploads
UPLOAD_STORAGE_BACKEND=local
UPLOAD_BUCKET=
UPLOAD_OBJECT_PREFIX=uploads
MAX_UPLOAD_BYTES=5242880

# Registration verification
# Development can expose the six-digit code in the API response for local testing.
# Production never exposes it and requires SMTP settings.
REGISTRATION_EXPOSE_CODE=true
REGISTRATION_CODE_TTL_MINUTES=10
REGISTRATION_COMPLETE_TTL_MINUTES=30
REGISTRATION_RESEND_SECONDS=60
REGISTRATION_MAX_ATTEMPTS=5
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_SSL=false
SMTP_USE_STARTTLS=true
