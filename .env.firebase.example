# Copy non-secret values into Cloud Run environment variables.
# Prefer Secret Manager for DATABASE_URL and GEO_SECRET_KEY.
# Do not commit real production secrets.

GEO_SECRET_KEY=replace-with-a-strong-production-secret
GEO_JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
APP_ENV=production
BUSINESS_TIMEZONE=Pacific/Auckland
ENABLE_DEV_SEED=false
AUTH_COOKIE_SECURE=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GENERAL_REQUESTS=300
RATE_LIMIT_GENERAL_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=30
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD_REQUESTS=30
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=60

# SQLite is acceptable only for a short Cloud Run demo. The live test backend uses Cloud SQL/Postgres.
DATABASE_URL=sqlite:///./geo_management.db
# Cloud SQL socket example:
# DATABASE_URL=postgresql+psycopg://geo_app:URL_ENCODED_PASSWORD@/geo_management?host=/cloudsql/geo-attendance-system-db9ca:australia-southeast1:geo-attendance-system
AUTO_MIGRATE=true
SQL_ECHO=false

# Replace these with your Firebase Hosting domains if the project id changes.
CORS_ORIGINS=https://geo-attendance-system-db9ca.web.app,https://geo-attendance-system-db9ca.firebaseapp.com

# Production cannot fall back to local disk. The Cloud Run service account needs
# object create, read, and delete access for this private bucket/prefix.
UPLOAD_STORAGE_BACKEND=gcs
UPLOAD_BUCKET=geo-attendance-system-db9ca-uploads
UPLOAD_OBJECT_PREFIX=uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880
